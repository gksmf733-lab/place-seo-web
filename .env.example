# Supabase (서버 + 브라우저 양쪽에서 사용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key 는 서버 전용. .env.local 에만 두고 NEXT_PUBLIC_ prefix 금지.
SUPABASE_SERVICE_ROLE_KEY=

# Browserbase (Vercel/AWS 서버리스 환경에서 원격 chromium 으로 스크래핑)
# 이 두 값이 모두 있으면 launchBrowser() 가 Browserbase CDP 로 접속,
# 없으면 로컬 playwright 사용.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Vercel AI Gateway (lib/*-analysis.ts 등에서 anthropic/claude-sonnet-4.6 호출)
# Vercel 에 배포하면 OIDC 토큰이 자동 주입되므로 보통 필요 없고,
# 로컬에서 AI 호출을 테스트하려면 설정.
AI_GATEWAY_API_KEY=
