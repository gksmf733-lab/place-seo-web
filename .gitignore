# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 런타임 저장소 (Job/Scrape/Override JSON 파일)
# data/sections 는 git에 트래킹 (템플릿 정본)
/data/jobs/
/data/scrapes/
/data/worksheets/
/data/overrides/

# Python legacy artifacts
/scripts/python/.venv/
/scripts/python/output/
/scripts/python/__pycache__/
**/__pycache__/

# Claude / Antigravity internal (기존 메타 툴킷)
/.agent/
/.claude/

# Editor
.vscode/
.idea/
*.swp

# local probe outputs
/data/probe/
.env*.local

# crawler service deps
/crawler/node_modules/
